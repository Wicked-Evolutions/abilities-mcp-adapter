{
    "name": "wicked-evolutions/abilities-mcp-adapter",
    "description": "Abilities MCP Adapter — exposes WordPress abilities as MCP tools, resources, and prompts.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "autoload": {
        "psr-4": {
            "WickedEvolutions\\McpAdapter\\": "src/"
        }
    },
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "yoast/phpunit-polyfills": "^2.0",
        "phpunit/phpunit": "^9.6"
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "allow-plugins": {}
    }
}
